# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/nanjil_mep

# Auth
# Generate with: npm run secret:jwt
JWT_SECRET=change-this-to-a-random-64-char-string-for-production-use

# URLs
CORS_ORIGIN=http://localhost:4001
FRONTEND_URL=http://localhost:4001
# COOKIE_DOMAIN=.yourdomain.com

# First admin account created by `npm run setup:initial`
INITIAL_ADMIN_FULL_NAME=Nanjil MEP Admin
INITIAL_ADMIN_EMAIL=admin@nanjilmep.com
INITIAL_ADMIN_PHONE=+918428489046
INITIAL_ADMIN_PASSWORD=change-this-before-production

# Admin notification recipients
ADMIN_EMAILS=admin@example.com

# SMTP email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Nanjil MEP <yourgmail@gmail.com>"
